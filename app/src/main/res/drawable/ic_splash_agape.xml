<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="128dp"
    android:height="128dp"
    android:viewportWidth="100"
    android:viewportHeight="100">
    <!-- 心形轮廓在 SplashActivity 中用 Canvas 虚线绘制；右下波纹为 Compose 动画，此处仅保留十字架与圆点 -->
    <!-- 十字架竖条（自顶端圆点向下） -->
    <path
        android:pathData="M50,25 L50,85"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#4F46E5"
        android:strokeLineCap="round"
        android:strokeWidth="3" />
    <!-- 十字架横条 -->
    <path
        android:pathData="M35,45 L65,45"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#4F46E5"
        android:strokeLineCap="round"
        android:strokeWidth="3" />
    <!-- 十字顶端实心圆点 -->
    <path
        android:pathData="M 50,25 m -2.5,0 a 2.5,2.5 0 1,1 5,0 a 2.5,2.5 0 1,1 -5,0"
        android:fillColor="#4F46E5" />
</vector>
